{
  "name": "idle-rpg-evolved",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Idle RPG Evolved — modular React + TypeScript rebuild with cloud saves.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
